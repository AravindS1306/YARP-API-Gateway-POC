{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "The service url/Azure AD which issues JWT",
    "Audience": "my-api",
    "Key": "Use a strong secret key here that matches everywhere"
  },
  "AllowedHosts": "*",
    "ReverseProxy": {
      "Routes": {
        "userRoute": {
          "ClusterId": "userCluster",
          "Match": { "Path": "/api/Auth/{**catch-all}" }
        },
        "chatRoute": {
          "ClusterId": "chatCluster",
          "Match": { "Path": "/api/Chat/{**catch-all}" }
        }
      },
      "Clusters": {
        "userCluster": {
          "Destinations": {
            "d1": { "Address": "route url to auth service" }
          }
        },
        "chatCluster": {
          "Destinations": {
            "d1": { "Address": "route url to chat service" }
          }
        }
      }
    }
  
}

